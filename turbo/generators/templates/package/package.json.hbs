
{
  "name": "@repo/{{snakeCase name}}",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build:js": "bun build src/index.ts --outdir dist --format esm --sourcemap --external:node",
    "build:types": "tsc --emitDeclarationOnly",
    "build": "bun run build:js && bun run build:types",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@repo/typescript": "workspace:*",
    "typescript": "catalog:"
  }
}
