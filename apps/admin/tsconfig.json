{
  "include": ["**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "paths": {
      "@/*": ["./src/*"],
      "#/*": ["./src/*"],
      "@repo/core": ["../../packages/core/src/index.ts"],
      "@repo/core/lib": ["../../packages/core/src/lib/index.ts"],
      "@repo/core/routing": ["../../packages/core/src/routing/index.ts"],
      "@repo/core/utils": ["../../packages/core/src/utils/index.ts"],
      "@repo/core/status": ["../../packages/core/src/status/index.ts"],
      "@repo/core/openapi": ["../../packages/core/src/openapi/index.ts"],
      "@repo/core/middleware": ["../../packages/core/src/middleware/index.ts"],
      "@repo/core/phrases": ["../../packages/core/src/phrases/index.ts"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  }
}
