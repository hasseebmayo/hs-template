{
	"name": "hasseebmayo",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"test": "turbo run test",
		"format-and-lint": "biome check .",
		"format-and-lint:fix": "biome check . --write",
		"check-types": "turbo run check-types",
		"lint-staged": "lint-staged",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@commitlint/cli": "^19.6.2",
		"@commitlint/config-conventional": "^19.6.2",
		"@turbo/gen": "^2.8.11",
		"husky": "^9.1.6",
		"lint-staged": "^16.2.7",
		"shadcn": "^3.8.5",
		"turbo": "^2.8.19",
		"typescript": "catalog:"
	},
	"engines": {
		"node": ">=18"
	},
	"packageManager": "bun@1.3.3",
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*",
			"tooling/*"
		],
		"catalog": {
			"typescript": "5.9.3",
			"hono": "4.11.3",
			"@hono/zod-openapi": "1.2.0",
			"stoker": "2.0.1",
			"zod": "4.3.3",
			"react": "19.2.4",
			"@types/react": "19.2.10",
			"@types/react-dom": "19.2.3",
			"react-dom": "19.2.4",
			"@tanstack/react-query": "5.90.21"
